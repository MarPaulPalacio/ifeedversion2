{
  "buildCommand": "cd frontend/SAPAT && npm install && npm run build",
  "outputDirectory": "frontend/SAPAT/dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-url.com/api/:path*"
    }
  ]
}
